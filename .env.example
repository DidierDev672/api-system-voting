# Configuración de Supabase
# Copia este archivo a .env y reemplaza con tus valores

# URL de tu proyecto Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co

# Llave pública (anon key)
SUPABASE_ANON_KEY=tu-anon-key-aqui

# Llave de servicio (service role key) - MANTENER PRIVADA
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Opcional: Variables de entorno para desarrollo
DEBUG=True
SECRET_KEY=django-insecure-key-for-development
